_bin="$(
  dirname \
    "$(command \
        -v \
        "env")")"
_lib="$(
  realpath \
    "${_bin}/../lib")"
_crash_bash="${_lib}/libcrash-bash/crash-bash"
_libevm="${_lib}/libevm/libevm"
_sourced \
  "${_crash_bash}" 2>/dev/null || \
  source \
    "${_crash_bash}"
_sourced \
  "${_libevm}"

_global_variables() {
  make_date=""
  device_loopback=""
  target_address=""
  quiet=""
  color=""
}

_requirements() {
  _check_cmd \
    "ifconfig" \
    "net-tools"
  _check_cmd \
    "awk" \
    "gawk"
  _check_cmd \
    "grep"
  _check_cmd \
    "ip" \
    "iproute2"
}

_devices_loopback_get() {
  ip \
    link \
      show |
    grep \
      -i \
      "<loopback,UP,LOWER_UP>" |
      awk \
        '{print $2}'
}

_mkrj45() {
  local \
    _device_loopback="${1}" \
    _target_address="${2}" \
    _devices_loopback=() \
    _ifconfig_args=() \
    _cmd=() \
    _msg=()
  _devices_loopback+=( $(
    _devices_loopback_get)
  )
  if [[ " ${_devices_loopback[*]} " == *" ${_device_loopback} "* ]]; then
    _msg=(
      "Device '${_device_loopback}'"
      "already exists."
    )
    _msg_error \
      "${_msg[*]}"
  else
    _alias_current="$((
      "${#_devices_loopback[@]}" - 1))"
    _msg=(
      "Creating loopback network device alias"
      "'${device_loopback}:${_alias_current}'."
      "on address '${_target_address}'."
    )
    _msg_info \
      "${_msg[*]}"
    _ifconfig_args+=(
      "${_device_loopback}:${_alias_current}"
      "${_target_address}"
      "netmask"
      "255.0.0.0"
      "up"
    )
    _cmd=(
      ifconfig
        "${_ifconfig_args[@]}"
    )
    _msg=(
      "Running '${_cmd[*]}'."
    )
    _msg_info \
      "${_msg[*]}"
    su \
      -c \
        "${_cmd[*]}"
  fi
}

_target_address_auto_detect() {
  local \
    _devices_loopback=() \
    _target_address
  _devices_loopback+=( $(
    _devices_loopback_get)
  )
  _device_current="$((
    "${#_devices_loopback[@]}" + 1))"
  _target_address="127.0.0.${_device_current}"
  _set_override \
    "target" \
    "address" \
    "${_target_address}"
}

_set_overrides() {
  if [[ -v override_quiet ]]; then
    quiet="${override_quiet}"
  elif [[ -z "${quiet}" ]]; then
    quiet="y"
  fi
  if [[ -v override_color ]]; then
    color="${override_color}"
  elif [[ -z "${color}" ]]; then
    color="n"
  fi
  _set_override \
    "make" \
    "date" \
    "$(_get_date_human)"
  _set_override \
    "device" \
    "loopback" \
    "lo"
  _target_address_auto_detect
}

_show_config() {
  _msg_info "${app_name} configuration"
  _msg_info "                  Make date:   ${make_date}"
  _msg_info "            Loopback device:   ${device_loopback}"
  _msg_info "             Target address:   ${target_address}"
}

_usage() {
  local \
    _usage_text
  IFS='' \
    read \
      -r \
      -d '' \
      _usage_text << \
        ENDUSAGETEXT || true

Add a loopback network device.

Usage:
  ${app_name}
    [options]
    <loopback-device-name>

  options:
     -A <target-address>      Target address for
                              the loopback device.
                              Default: ${target_address}

     -h                       This message.
     -c                       Enable color output
     -v                       Enable verbose output

ENDUSAGETEXT
  _printf \
    '%s\n' \
    "${_usage_text}"
  exit \
    "${1}"
}

_cmdline_parse() {
  local \
    _args=() \
    _getopts_opts
  _args+=(
    "$@"
  )
  _getopts_opts="$(
    printf \
      "%s" \
      "A:" \
      "cvh")"
  while \
    getopts \
      "${_getopts_opts}" \
      arg; do
    case \
      "${arg}" in
      A)
        override_target_address="${OPTARG}" ;;
      c)
        override_color="y" ;;
      v)
        override_quiet="n" ;;
      h)
        _set_overrides
           _usage \
             0 ;;
      *)
        if [[ " ${_getopts_opts} " != *"${arg}"* ]]; then
          _msg=(
            "Invalid argument '${arg}'."
          )
          _msg_error \
            "${_msg[*]}" \
            0
          _set_overrides
          _usage \
            1
        fi ;;
    esac
  done
  shift \
    $((
      OPTIND - 1 ))
  if (( 0 < "${#}" )); then
    device_loopback="${1}"
  fi
}

_globals
_global_variables
_cmdline_parse \
  "$@"
_set_overrides
_show_config
app_opts=(
  "${device_loopback}"
  "${target_address}"
)
_mkrj45 \
  "${app_opts[@]}"

